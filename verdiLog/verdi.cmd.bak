verdiSetActWin -dock widgetDock_<Inst._Tree>
verdiSetActWin -win $_nWave2
verdiSetActWin -dock widgetDock_<Inst._Tree>
srcHBSelect "top.dut" -win $_nTrace1
srcHBSelect "top.tb" -win $_nTrace1
